    "pop_size_female": -1,
    "pop_size": -1,
    "registered_voters_male": -1,
    "registered_voters_female": -1,
    "registered_voters_total": -1,
    "voters_male": -1,
    "voters_female": -1,
    "voters_total": -1,
    "participation_rate": -1,
    "null_ballots": -1,
    "expressed_votes": -1,
    "blank_ballots_count": -1,
    "blank_ballots_pct": -1,
    "unregistered_voters_count": -1
  },
  "candidate_results": {
    "row_mode": {
      "party_idx": -1,
